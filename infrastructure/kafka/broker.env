# Project Aegis — Kafka Broker Environment Configuration
# KRaft mode (no Zookeeper). Single-node development topology.
# For multi-broker production, increase KAFKA_CFG_OFFSETS_TOPIC_REPLICATION_FACTOR
# and KAFKA_CFG_TRANSACTION_STATE_LOG_REPLICATION_FACTOR to match broker count.

KAFKA_NODE_ID=1
KAFKA_PROCESS_ROLES=broker,controller
KAFKA_CONTROLLER_QUORUM_VOTERS=1@aegis-kafka:9093

# Listener configuration
# INTERNAL: container-to-container communication
# EXTERNAL: host-machine connectivity for local backend execution
# CONTROLLER: KRaft consensus
KAFKA_LISTENERS=INTERNAL://:19092,EXTERNAL://:9092,CONTROLLER://:9093
KAFKA_ADVERTISED_LISTENERS=INTERNAL://aegis-kafka:19092,EXTERNAL://localhost:9092
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=INTERNAL:PLAINTEXT,EXTERNAL:PLAINTEXT,CONTROLLER:PLAINTEXT
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_INTER_BROKER_LISTENER_NAME=INTERNAL

# Topic defaults
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true
KAFKA_NUM_PARTITIONS=3
KAFKA_DEFAULT_REPLICATION_FACTOR=1
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
KAFKA_MIN_INSYNC_REPLICAS=1

# Producer idempotency
KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS=0
