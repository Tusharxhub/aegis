# Project Aegis — Kafka Broker Environment Configuration
# KRaft mode (no Zookeeper). Single-node development topology.
# For multi-broker production, increase KAFKA_CFG_OFFSETS_TOPIC_REPLICATION_FACTOR
# and KAFKA_CFG_TRANSACTION_STATE_LOG_REPLICATION_FACTOR to match broker count.

ALLOW_PLAINTEXT_LISTENER=yes
KAFKA_ENABLE_KRAFT=yes
KAFKA_CFG_NODE_ID=1
KAFKA_CFG_PROCESS_ROLES=broker,controller
KAFKA_CFG_CONTROLLER_QUORUM_VOTERS=1@aegis-kafka:9093

# Listener configuration
# INTERNAL: container-to-container communication
# EXTERNAL: host-machine connectivity for local backend execution
# CONTROLLER: KRaft consensus
KAFKA_CFG_LISTENERS=INTERNAL://:9092,EXTERNAL://:9094,CONTROLLER://:9093
KAFKA_CFG_ADVERTISED_LISTENERS=INTERNAL://aegis-kafka:9092,EXTERNAL://localhost:9092
KAFKA_CFG_LISTENER_SECURITY_PROTOCOL_MAP=INTERNAL:PLAINTEXT,EXTERNAL:PLAINTEXT,CONTROLLER:PLAINTEXT
KAFKA_CFG_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_CFG_INTER_BROKER_LISTENER_NAME=INTERNAL

# Topic defaults
KAFKA_CFG_AUTO_CREATE_TOPICS_ENABLE=false
KAFKA_CFG_NUM_PARTITIONS=3
KAFKA_CFG_DEFAULT_REPLICATION_FACTOR=1
KAFKA_CFG_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_CFG_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_CFG_TRANSACTION_STATE_LOG_MIN_ISR=1
KAFKA_CFG_MIN_INSYNC_REPLICAS=1

# Producer idempotency
KAFKA_CFG_ENABLE_IDEMPOTENCE=true

# Log storage
KAFKA_CFG_LOG_DIRS=/bitnami/kafka/data
KAFKA_CFG_LOG_RETENTION_HOURS=168
KAFKA_CFG_LOG_SEGMENT_BYTES=1073741824

# Message size — allow large log payloads from containers
KAFKA_CFG_MESSAGE_MAX_BYTES=10485760
KAFKA_CFG_REPLICA_FETCH_MAX_BYTES=10485760
