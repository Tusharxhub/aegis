generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Service {
  id          String @id @default(uuid())
  name        String
  containerId String @unique
  status      String

  events InfrastructureEvent[]
}

model InfrastructureEvent {
  id        String  @id @default(uuid())
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  eventType String
  rawLogs   String   @db.Text
  timestamp DateTime @default(now())

  remediation RemediationPlan?
}

model RemediationPlan {
  id      String              @id @default(uuid())
  eventId String              @unique
  event   InfrastructureEvent @relation(fields: [eventId], references: [id])

  aiAnalysis      String @db.Text
  confidenceScore Float
  suggestedAction String
  status          String

  execution ActionExecution?
}

model ActionExecution {
  id     String          @id @default(uuid())
  planId String          @unique
  plan   RemediationPlan @relation(fields: [planId], references: [id])

  actionTaken   String
  isSuccessful  Boolean
  executionLogs String? @db.Text

  executedAt DateTime @default(now())
}
