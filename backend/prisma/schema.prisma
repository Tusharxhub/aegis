datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum ServiceStatus {
  HEALTHY
  DEGRADED
  CRASHED
  RESTARTING
  UNKNOWN
}

enum EventType {
  DIE
  OOM
  KILL
  HEALTH_CHECK_FAIL
}

enum RemediationStatus {
  PENDING
  APPROVED
  EXECUTING
  COMPLETED
  FAILED
  SKIPPED
}

enum ActionType {
  RESTART_CONTAINER
  STOP_CONTAINER
  IGNORE
}

enum RiskLevel {
  LOW
  HIGH
}

// ─────────────────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────────────────

model Service {
  id           String        @id @default(uuid())
  name         String
  imageName    String
  containerId  String        @unique
  status       ServiceStatus @default(HEALTHY)
  exitCode     Int?
  restartCount Int           @default(0)
  lastSeenAt   DateTime      @default(now())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  events InfrastructureEvent[]

  @@index([containerId])
  @@index([status])
  @@map("services")
}

model InfrastructureEvent {
  id        String    @id @default(uuid())
  serviceId String
  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  eventType EventType
  exitCode  Int?
  rawLogs   String    @db.Text
  metadata  Json?
  timestamp DateTime  @default(now())
  createdAt DateTime  @default(now())

  embedding   IncidentEmbedding?
  remediation RemediationPlan?

  @@index([serviceId])
  @@index([eventType])
  @@index([timestamp])
  @@map("infrastructure_events")
}

model IncidentEmbedding {
  id           String              @id @default(uuid())
  eventId      String              @unique
  event        InfrastructureEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  embedding    Float[]             // Store sentence embeddings array
  incidentType String              // e.g. OOM_KILL, DB_TIMEOUT
  createdAt    DateTime            @default(now())

  @@map("incident_embeddings")
}

model RemediationPlan {
  id              String            @id @default(uuid())
  eventId         String            @unique
  event           InfrastructureEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  aiAnalysis      String            @db.Text
  confidenceScore Float
  suggestedAction ActionType
  riskLevel       RiskLevel         @default(LOW)
  reasoning       String            @db.Text
  status          RemediationStatus @default(PENDING)
  processingTimeMs Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  execution ActionExecution?

  @@index([status])
  @@index([confidenceScore])
  @@map("remediation_plans")
}

model ActionExecution {
  id            String          @id @default(uuid())
  planId        String          @unique
  plan          RemediationPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  actionTaken   String
  isSuccessful  Boolean
  executionLogs String?         @db.Text
  durationMs    Int?
  errorMessage  String?
  executedAt    DateTime        @default(now())

  @@index([isSuccessful])
  @@index([executedAt])
  @@map("action_executions")
}

model MetricsSnapshot {
  id          String   @id @default(uuid())
  cpuUsage    Float
  memoryUsage Float
  diskUsage   Float
  timestamp   DateTime @default(now())

  @@index([timestamp])
  @@map("metrics_snapshots")
}
