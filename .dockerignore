# ─────────────────────────────────────────────────────────────────────────────
# Project Aegis — Docker Ignore
# Optimizes Docker builds by excluding unnecessary files
# ─────────────────────────────────────────────────────────────────────────────

# Dependencies
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build output
dist/
build/
out/

# Coverage & test
coverage/
.nyc_output/
*.spec.ts
*.test.ts
__tests__/

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Documentation
*.md
docs/
LICENSE

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# CI/CD
.github/
.circleci/
.travis.yml

# Environment (never bake secrets into images)
.env
.env.*
!.env.example

# Infrastructure
infrastructure/
scripts/

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
.venv/
venv/

# AI Engine specific
services/ai-engine/models/
services/ai-engine/vectorstore/storage/
services/ai-engine/*.bin
services/ai-engine/*.pt
services/ai-engine/*.onnx

# CLI (not needed in backend images)
cli/

# Root package files (each service has its own)
package-lock.json
package.json
tsconfig*.json
nest-cli.json
eslint.config.mjs
.prettierrc
